# ---------------------------------------------------------------------------
# Copy to .env.local for local dev, and set these in Vercel project settings.
# NEVER commit real values. Only NEXT_PUBLIC_* vars reach the browser.
# ---------------------------------------------------------------------------

# Supabase (public — safe for the browser, protected by Row-Level Security)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Anthropic — SERVER ONLY. Powers photo OCR + the proposal "what we found" narrative.
# The app runs without it (manual entry + recommendations + proposals all work);
# only the AI features are disabled until this is set. Never expose to the client.
ANTHROPIC_API_KEY=sk-ant-your-key

# Restrict sign-up / login to this email domain (no leading @).
ALLOWED_EMAIL_DOMAIN=adt.com
